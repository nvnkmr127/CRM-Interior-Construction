{
  "name": "crm-server",
  "version": "1.0.0",
  "private": true,
  "main": "src/app.js",
  "scripts": {
    "build": "echo 'No build step required for server'",
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch --runInBand"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/s3-request-presigner": "^3.1068.0",
    "@google/genai": "^2.8.0",
    "axios": "^1.18.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "otplib": "^13.4.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.15.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "redis": "^6.0.0",
    "uuid": "^9.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "setupFilesAfterEnv": [],
    "moduleNameMapper": {
      "^otplib$": "<rootDir>/src/__mocks__/otplib.js"
    }
  }
}
