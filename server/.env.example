# Port for the Express server to run on
PORT=4000

# Application environment (development, production, etc.)
NODE_ENV=development

# Database connection URL string (REQUIRED)
DATABASE_URL=postgres://user:pass@localhost:5432/crm

# Secret key for JWT signing (REQUIRED)
JWT_SECRET=super_secret_jwt_key

# Secret key for JWT refresh tokens (REQUIRED)
JWT_REFRESH_SECRET=super_secret_refresh_key

# URL of the client application (CORS origin)
CLIENT_URL=http://localhost:5173

# S3 Bucket name for file uploads
S3_BUCKET=my-bucket

# S3 Region
S3_REGION=us-east-1

# AWS Access Key ID
AWS_ACCESS_KEY_ID=aws_access_key

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=aws_secret_key
