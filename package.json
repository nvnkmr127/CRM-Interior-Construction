{
  "name": "crm-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "build": "npm run build -w server && npm run build -w client",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^25.9.3",
    "concurrently": "^10.0.3",
    "eslint": "^10.5.0",
    "globals": "^16.2.0",
    "prettier": "^3.8.4"
  },
  "dependencies": {
    "pg": "^8.21.0"
  }
}
